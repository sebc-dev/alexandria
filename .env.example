# Alexandria Configuration
# =========================
# Quick start:
#   cp .env.example .env
#   # Edit DOCS_PATH to point to your documentation
#   docker compose up -d

# =============================================================================
# Documentation Path
# =============================================================================
# Path to your markdown documentation directory on the host machine.
# This directory will be mounted read-only into the container.
DOCS_PATH=./docs

# =============================================================================
# Database Configuration
# =============================================================================
# These settings are pre-configured for the bundled PostgreSQL container.
# Only change these if you want to use an external PostgreSQL instance.
# Note: External PostgreSQL must have pgvector and Apache AGE extensions.

DB_HOST=postgres
DB_PORT=5432
DB_NAME=alexandria
DB_USER=alexandria
DB_PASSWORD=alexandria

# =============================================================================
# Logging
# =============================================================================
# Application logging level. Valid values: DEBUG, INFO, WARN, ERROR
# DEBUG is verbose - useful for troubleshooting
# INFO is recommended for normal operation
LOG_LEVEL=INFO

# =============================================================================
# Resource Limits
# =============================================================================
# Container memory limit. The ONNX embedding model requires significant memory.
# Breakdown: ~500MB for ONNX model, ~500MB for JVM heap, ~1GB buffer for GC
# Minimum recommended: 2g
# Increase to 4g if processing large documentation sets
MEM_LIMIT=2g
